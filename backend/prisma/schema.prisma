generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  firebaseUid     String            @unique
  email           String            @unique
  name            String?
  avatarUrl       String?
  googleId        String?           @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  role            Role              @default(CLIENT)
  isGoogleAccount Boolean           @default(false)
  threads         ChatThread[]
  contexts        Context[]
  customTheme     CustomTheme?
  documents       DocDocument[]
  docThemes       DocTheme[]
  slideTemplates  SlideTemplate[]
  assignedTasks   Task[]            @relation("TaskAssignee")
  transcripts     Transcript[]
  integrations    UserIntegration[]
  projects        Project[]
  diagrams        Diagram[]
}

model UserIntegration {
  id           String              @id @default(cuid())
  userId       String
  provider     IntegrationProvider
  status       IntegrationStatus   @default(CONNECTED)
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  accountId    String?
  accountName  String?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
}

model CustomTheme {
  id                 String   @id @default(cuid())
  userId             String   @unique
  primaryColor       String?
  secondaryColor     String?
  backgroundColor    String?
  surfaceColor       String?
  textPrimaryColor   String?
  textSecondaryColor String?
  fontFamily         String?
  headingFontFamily  String?
  borderRadius       Float?
  density            Int?
  configJson         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startedAt   DateTime?
  endedAt     DateTime?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tasks       Task[]
  transcripts Transcript[]
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("projects")
}

model Transcript {
  id         String               @id @default(cuid())
  title      String?
  source     TranscriptSource     @default(MANUAL)
  language   String?
  summary    String?
  transcript String?
  rawUrl     String?
  metadata   Json?
  recordedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  projectId  String?
  userId     String
  taskLinks  TaskTranscriptLink[]
  project    Project?             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([source])
}

model Task {
  id                 String               @id @default(cuid())
  title              String
  description        String?
  status             TaskStatus           @default(BACKLOG)
  priority           TaskPriority         @default(MEDIUM)
  lane               String?              @db.VarChar(64)
  position           Int                  @default(0)
  canvasX            Float?               @map("canvas_x")
  canvasY            Float?               @map("canvas_y")
  canvasWidth        Float?               @map("canvas_width")
  canvasHeight       Float?               @map("canvas_height")
  startDate          DateTime?
  dueDate            DateTime?
  completedAt        DateTime?
  estimatedMinutes   Int?
  actualMinutes      Int?
  metadata           Json?
  assigneeId         String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  acceptanceCriteria String?
  summary            String?
  projectId          String
  assignee           User?                @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dependencies       TaskDependency[]     @relation("TaskDependencyDependants")
  dependants         TaskDependency[]     @relation("TaskDependencyDependencies")
  transcriptLinks    TaskTranscriptLink[]

  @@index([projectId])
  @@index([status])
  @@index([lane, position])
  @@index([assigneeId])
}

model TaskDependency {
  id              String         @id @default(cuid())
  taskId          String
  dependsOnTaskId String
  type            DependencyType @default(BLOCKS)
  createdAt       DateTime       @default(now())
  dependsOn       Task           @relation("TaskDependencyDependants", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  task            Task           @relation("TaskDependencyDependencies", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
}

model TaskTranscriptLink {
  taskId       String
  transcriptId String
  relevance    Float?
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  transcript   Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@id([taskId, transcriptId])
}

model Context {
  id          String        @id @default(cuid())
  userId      String
  name        String        @db.VarChar(120)
  description String?
  color       String?       @db.VarChar(24)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  files       ContextFile[]

  @@index([userId, name])
}

model ContextFile {
  id         String   @id @default(cuid())
  contextId  String
  bucketPath String   @db.VarChar(255)
  fileName   String   @db.VarChar(180)
  mimeType   String   @db.VarChar(128)
  sizeBytes  Int      @default(0)
  metadata   Json?
  createdAt  DateTime @default(now())
  context    Context  @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@index([contextId])
}

model ChatThread {
  id           String        @id @default(cuid())
  userId       String
  title        String        @default("New Chat")
  contextIds   String[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  englishLevel String?
  messages     ChatMessage[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  role      ChatRole
  content   String
  createdAt DateTime   @default(now())
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model SlideTemplate {
  id              String            @id @default(cuid())
  userId          String
  name            String            @db.VarChar(120)
  description     String?
  primaryColor    String?           @db.VarChar(24)
  secondaryColor  String?           @db.VarChar(24)
  backgroundColor String?           @db.VarChar(24)
  headingFont     String?           @db.VarChar(80)
  bodyFont        String?           @db.VarChar(80)
  backgroundStyle String?           @db.VarChar(24)
  cardStyle       String?           @db.VarChar(24)
  logoUrl         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  presentations   Presentation[]
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  slideTypes      SlideTypeConfig[]

  @@index([userId])
}

model SlideTypeConfig {
  id               String        @id @default(cuid())
  templateId       String
  slideTypeKey     String        @db.VarChar(64)
  displayName      String        @db.VarChar(120)
  description      String?
  parametersSchema Json
  position         Int           @default(0)
  createdAt        DateTime      @default(now())
  template         SlideTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Presentation {
  id         String        @id @default(cuid())
  userId     String
  templateId String
  title      String
  slidesJson Json
  contextIds String[]
  status     String        @default("DRAFT") @db.VarChar(24)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  template   SlideTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model DocTheme {
  id              String        @id @default(cuid())
  userId          String
  name            String        @db.VarChar(120)
  headingFont     String        @default("Inter") @db.VarChar(80)
  bodyFont        String        @default("Inter") @db.VarChar(80)
  primaryColor    String        @default("#4361EE") @db.VarChar(24)
  accentColor     String        @default("#7c3aed") @db.VarChar(24)
  backgroundColor String        @default("#ffffff") @db.VarChar(24)
  textColor       String        @default("#0f172a") @db.VarChar(24)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  documents       DocDocument[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DocDocument {
  id            String    @id @default(cuid())
  userId        String
  themeId       String?
  title         String
  content       String
  status        String    @default("DRAFT") @db.VarChar(24)
  isPublic      Boolean   @default(false)
  contextIds    String[]
  transcriptIds String[]
  prompt        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  theme         DocTheme? @relation(fields: [themeId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
}

enum DiagramType {
  FLOWCHART
  SEQUENCE
  GANTT
  MINDMAP
  CLASS
  ER
  ARCHITECTURE
}

enum DiagramStatus {
  GENERATING
  DRAFT
  FAILED
}

model Diagram {
  id            String        @id @default(cuid())
  userId        String
  title         String
  prompt        String
  mermaidCode   String?
  type          DiagramType
  status        DiagramStatus @default(DRAFT)
  contextIds    String[]
  transcriptIds String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  ADMIN
  CLIENT
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TranscriptSource {
  MANUAL
  RECORDING
  UPLOAD
  IMPORTED
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  BLOCKED
  COMPLETED
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DependencyType {
  BLOCKS
  RELATES_TO
  DUPLICATES
}

enum IntegrationProvider {
  JIRA
  LINEAR
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum ChatRole {
  USER
  ASSISTANT
}
