{
  "name": "plan-ai-recorder",
  "version": "1.0.17",
  "private": true,
  "author": {
    "name": "BLUEBERRYBYTES SERVICES FZCO",
    "email": "projects@blueberrybytes.com"
  },
  "description": "Plan AI Desktop Recorder — capture any meeting and generate tasks with AI",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "prebuild": "node scripts/prebuild-native.js",
    "predev": "node scripts/prebuild-native.js || true",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "sentry-sourcemaps": "npx @sentry/wizard@latest -i sourcemaps --saas --org blueberrybytes-services-fzco --project plan-ai-recorder-electron",
    "preview": "electron-vite preview",
    "package": "npm run package:mac && npm run package:win && npm run package:linux",
    "package:mac": "set -a && source .env.production && set +a && node scripts/bump-version.js && electron-vite build && electron-builder --mac",
    "package:win": "set -a && source .env.production && set +a && node scripts/bump-version.js && electron-vite build && electron-builder --win --x64",
    "package:linux": "set -a && source .env.production && set +a && node scripts/bump-version.js && electron-vite build && electron-builder --linux",
    "release:win": "set -a && source .env.production && set +a && electron-vite build && electron-builder --win --x64 -p always",
    "release:linux": "set -a && source .env.production && set +a && electron-vite build && electron-builder --linux -p always",
    "build:local:mac": "set -a && source .env.production && set +a && electron-vite build && electron-builder --mac -p never",
    "release:mixed": "node scripts/bump-version.js && yarn release:win && yarn release:linux && set -a && source .env.production && set +a && electron-vite build && electron-builder --mac -p never",
    "publish-release": "node scripts/publish-draft.js",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^5.15.18",
    "@sentry/electron": "^7.11.0",
    "@sentry/vite-plugin": "^5.2.0",
    "axios": "^1.13.6",
    "electron-updater": "^6.8.3",
    "firebase": "^10.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'yarn typecheck'"
    ]
  },
  "build": {
    "appId": "com.blueberrybytes.plan-ai-recorder",
    "productName": "Plan AI Recorder",
    "publish": [
      {
        "provider": "github",
        "owner": "blueberrybytes",
        "repo": "plan-ai-recorder-releases",
        "releaseType": "draft"
      }
    ],
    "buildVersion": "95",
    "protocols": [
      {
        "name": "Plan AI Recorder",
        "schemes": [
          "blueberrybytes-recorder"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "12.0.0",
      "target": [
        "dmg",
        "zip",
        "mas"
      ],
      "binaries": [
        "macos/AudioCapture",
        "macos/MicActivity"
      ],
      "extraFiles": [
        {
          "from": "macos/AudioCapture",
          "to": "Resources/bin/AudioCapture"
        },
        {
          "from": "macos/MicActivity",
          "to": "Resources/bin/MicActivity"
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "macos/entitlements.plist",
      "entitlementsInherit": "macos/entitlements.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Plan AI Recorder securely captures your microphone input and transmits it to our AI servers to transcribe your voice during meetings.",
        "NSScreenCaptureUsageDescription": "Plan AI Recorder securely captures your system audio output and transmits it to our AI servers to transcribe video meetings. No visual UI screen content is recorded.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mas": {
      "entitlements": "macos/entitlements.mas.plist",
      "entitlementsInherit": "macos/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/mas.provisionprofile",
      "identity": "BLUEBERRYBYTES SERVICES FZCO (8NN84K7QKJ)",
      "hardenedRuntime": false,
      "binaries": [
        "macos/AudioCapture",
        "macos/MicActivity"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
