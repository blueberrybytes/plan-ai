ENV="local"
PORT=8080
API_ADMIN_KEY="test123"

# Log
LOG_LEVEL=info

# Frontend
FRONTEND_URL="http://localhost:3000"

# CORS — comma-separated list of allowed origins for production.
# Leave empty/unset for local dev (allows all origins).
# Example: CORS_ORIGINS="https://plan-ai.blueberrybytes.com,https://app.plan-ai.com"
CORS_ORIGINS=""

# Quadrant
QDRANT_URL=http://127.0.0.1:6333
#QDRANT_API_KEY=planai123            # or leave blank if auth disabled
QDRANT_CONTEXT_COLLECTION=context_files

# Prisma
DATABASE_URL="postgresql://planai:planai123@localhost/planai_db?schema=public"

# Google
FIREBASE_SERVICE_KEY="="
FIREBASE_STORAGE_BUCKET=""

# OpenAI / LLMs
# OPENAI_API_KEY is now OPTIONAL: embeddings run through OpenRouter by default
# (openai/text-embedding-3-small). Keep it only as a legacy embeddings fallback.
OPENAI_API_KEY="sk-proj-xxxx"
# Used for both LLM generation AND embeddings (platform fallback for courtesy /
# unconfigured workspaces). BYOK workspaces bring their own OpenRouter key.
OPENROUTER_API_KEY="sk-or-v1-xxxx"

# Groq
GROQ_API_KEY="gsk_xxxx"

# Deepgram
DEEPGRAM_API_KEY="xxxx"

#GOOGLE_LOGS_SERVICE_KEY=""

# Jira
JIRA_CLIENT_ID=""
JIRA_CLIENT_SECRET=""
JIRA_REDIRECT_URI="http://localhost:8080/api/jira/callback"

# Trello
TRELLO_GLOBAL_API_KEY=""

# Linear
LINEAR_CLIENT_ID=""
LINEAR_CLIENT_SECRET=""
LINEAR_REDIRECT_URI="http://localhost:8080/api/linear/callback"
LINEAR_WEBHOOK_SECRET=""

# GitHub App Integration
GITHUB_APP_ID=""
GITHUB_WEBHOOK_SECRET=""                  # The Webhook Secret
GITHUB_PRIVATE_KEY=""             # Format this by replacing actual newlines with \n so it fits on one line

# Queue
REDIS_URL=redis://localhost:6379
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=admin

# Google OAuth API (For Google Drive Integration)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8080/api/google/callback"

# Sentry Backend Integration
# SENTRY_DSN=https://0de65f7a318241dec11ea919590f0698@o4511196762734592.ingest.us.sentry.io/4511197640654848
# NODE_ENV=development

RESEND_API_KEY=""

FROM_EMAIL="noreply@plan-ai.blueberrybytes.com"

MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:8080/api/microsoft/callback"
BACKEND_URL=https://your-production-api-url.com   # or http://localhost:8080 for local
APP_URL="https://plan-ai.blueberrybytes.com"

# GitNexus MCP Server
USE_GITNEXUS="false"
GITNEXUS_MCP_URL="http://localhost:4747/api/mcp"

# Voice AI Microservice
VOICE_AI_URL="http://localhost:8001"
VOICE_AI_API_KEY=""                    # Shared secret between backend and voice-ai service
# VOICE_REQUEST_TIMEOUT=180            # Voice-ai request timeout in seconds (default: 180)

# Notion API Connection
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""
NOTION_REDIRECT_URI="http://localhost:8080/api/notion/callback"

# Asana OAuth
ASANA_CLIENT_ID=""
ASANA_CLIENT_SECRET=""
ASANA_REDIRECT_URI="http://localhost:8080/api/asana/callback"

# ─── Stripe Billing ──────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys (use TEST keys for local)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs — one per tier (created in Stripe Dashboard > Products)
STRIPE_PRICE_PRO_BYOK=""
STRIPE_PRICE_PRO_MANAGED=""
STRIPE_PRICE_BUSINESS_BYOK=""
STRIPE_PRICE_BUSINESS_MANAGED=""

# Where Stripe Checkout redirects after success/cancel (relative to APP_URL)
STRIPE_CHECKOUT_SUCCESS_PATH="/billing?status=success"
STRIPE_CHECKOUT_CANCEL_PATH="/billing?status=canceled"

# Free-trial length (in days) applied to BYOK plans only. MANAGED plans never
# get a trial (we'd pay the AI spend). Card is still collected upfront. Set to 0
# to disable BYOK trials entirely.
STRIPE_BYOK_TRIAL_DAYS="14"

# ─── Telegram "Berry" sales bot ───────────────────────────────────────────────
# Token from @BotFather. Without it the webhook answers but sends nothing.
TELEGRAM_BOT_TOKEN=""

# Secret registered with setWebhook(secret_token=...). Telegram echoes it back in
# the X-Telegram-Bot-Api-Secret-Token header; it is the ONLY auth on the public
# webhook, so generate a long random value and never reuse it.
TELEGRAM_WEBHOOK_SECRET=""

# Workspace whose BYOK keys pay for prospect generations (marketing spend, not
# customer spend), and the service user that owns the generated docs.
TELEGRAM_WORKSPACE_ID=""
TELEGRAM_SERVICE_USER_ID=""

# Proposals allowed per chat per 24h. Guards our OpenRouter credits.
TELEGRAM_RATE_LIMIT="5"

# Messages allowed per chat per 24h, generated or not. Every message costs a
# cheap triage call, so chatter needs its own ceiling.
TELEGRAM_MESSAGE_LIMIT="30"

# Deepgram language for voice notes. "multi" covers ~10 languages but NOT
# Catalan — it returns an EMPTY transcript rather than an error. Set to "ca"
# (or "es") monolingually if the bot talks to Catalan-speaking prospects.
TELEGRAM_TRANSCRIPTION_LANGUAGE="multi"

# Where lead alerts go. Comma-separated for several recipients. Without this the
# bot delivers proposals and nobody on the team finds out. Needs RESEND_API_KEY.
TELEGRAM_LEAD_NOTIFY_EMAIL=""

# Push each lead's extracted tasks into Linear. Off by default: every curious
# stranger would otherwise land as tickets on the team's board.
TELEGRAM_SYNC_TO_LINEAR="false"
