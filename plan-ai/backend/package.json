{
  "name": "backend",
  "version": "3.1.0",
  "description": "",
  "engines": {
    "node": "22.17.1"
  },
  "scripts": {
    "dev": "env-cmd -f .env nodemon src/server.ts",
    "start": "node dist/server.js",
    "build": "yarn generate:swagger && tsc",
    "build:ts": "tsc",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:ci": "yarn lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --runInBand",
    "test:ui": "vitest --ui",
    "prisma:dev": "npx prisma migrate dev --name",
    "prisma:studio": "npx prisma studio",
    "prisma:generate": "npx prisma generate",
    "prisma:deploy": "npx prisma migrate deploy",
    "prisma:reset": "npx prisma migrate reset --force --skip-seed",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:migrate": "npx prisma migrate dev",
    "generate:swagger": "npx tsoa spec && npx tsoa routes",
    "format": "prettier --cache --write \"src/**/*.{ts,tsx,js,json}\""
  },
  "keywords": [
    "backend"
  ],
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "resolutions": {
    "rollup": "4.52.5"
  },
